route:
  receiver: "null"
  routes:
  - receiver: mynamespace/myamc/test
    matchers:
    - namespace="mynamespace"
    continue: true
receivers:
- name: "null"
- name: mynamespace/myamc/test
  slack_configs:
  - api_url: https://slack.com/api/chat.postMessage
    http_config:
      authorization:
        type: bearer
        credentials: abcdef123456
    update_message: true
templates: []
