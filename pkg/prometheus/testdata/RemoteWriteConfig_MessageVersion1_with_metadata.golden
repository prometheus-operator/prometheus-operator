global:
  scrape_interval: 30s
  external_labels:
    prometheus: default/test
    prometheus_replica: $(POD_NAME)
  evaluation_interval: 30s
scrape_configs: []
storage:
  tsdb:
    retention:
      time: 24h
remote_write:
- url: http://example.com
  protobuf_message: prometheus.WriteRequest
  metadata_config:
    send: true
