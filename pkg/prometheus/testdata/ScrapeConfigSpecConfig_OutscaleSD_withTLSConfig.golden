global:
  scrape_interval: 30s
  external_labels:
    prometheus: default/test
    prometheus_replica: $(POD_NAME)
  evaluation_interval: 30s
scrape_configs:
- job_name: scrapeConfig/default/testscrapeconfig1
  outscale_sd_configs:
  - tls_config:
      ca_file: /etc/prometheus/certs/0_default_tls_ca
      cert_file: /etc/prometheus/certs/0_default_tls_cert
      key_file: /etc/prometheus/certs/0_default_tls_private-key
    region: eu-west-2
    access_key: AKXXXXXXXXXXXXXXXXXX
    secret_key: SK0000000000000000000000000000000000000000
  relabel_configs:
  - source_labels:
    - job
    target_label: __tmp_prometheus_job_name
storage:
  tsdb:
    retention:
      time: 24h
